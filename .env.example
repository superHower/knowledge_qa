# 环境变量配置（Docker Compose 版本）

# ===================
# 应用配置
# ===================
APP_NAME="Knowledge QA Agent"
APP_VERSION="0.1.0"
DEBUG=false

# ===================
# OpenAI API 配置 ⭐ 必需
# ===================
# ⚠️ 重要：请替换为您自己的 API 密钥
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LLM 生成参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# ===================
# MySQL 数据库 ⭐ 独立容器
# ===================
# Docker Compose 环境：使用服务名 "mysql" 自动解析
# 生产环境建议修改 MYSQL_ROOT_PASSWORD！
DATABASE_URL=mysql+aiomysql://root:123456@mysql:3306/knowledge_qa?charset=utf8mb4
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=knowledge_qa

# ===================
# Qdrant 向量数据库 ⭐ 独立容器
# ===================
# Docker Compose 环境：使用服务名 "qdrant"
QDRANT_HOST=qdrant
QDRANT_PORT=6400
QDRANT_COLLECTION_NAME=knowledge_base

# ===================
# 文档处理
# ===================
UPLOAD_DIR=./uploads
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ===================
# RAG 配置
# ===================
TOP_K=5
SIMILARITY_THRESHOLD=0.5

# ===================
# 日志
# ===================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ===================
# CORS 配置
# ===================
CORS_ORIGINS=["*"]
